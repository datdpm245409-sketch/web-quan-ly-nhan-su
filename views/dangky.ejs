<!DOCTYPE html> 
<html lang="vi"> 
<head> 
    <meta charset="utf-8" /> 
    <meta name="viewport" content="width=device-width, initial-scale=1" /> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" /> 
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <title>Đăng ký - it for lie</title> 

    <style>
        /* Dùng chung nền mộng mơ của trang Đăng nhập */
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 2rem 0; /* Padding để form không bị dính sát viền trên mobile */
        }

        /* Khung kính mờ (Glassmorphism) */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        /* Nút bấm chuyển màu */
        .btn-gradient {
            background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
            border: none;
            color: white;
            transition: all 0.3s ease;
        }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 254, 0.4);
            color: white;
        }

        /* Style ô nhập liệu */
        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(142, 197, 252, 0.25);
            border-color: #8ec5fc;
        }
        
        .icon-box {
            background: #f8f9fa;
            color: #4facfe;
        }
    </style>
</head> 
 
<body> 
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
                
                <div class="glass-card p-4 p-sm-5"> 
                    
                    <div class="text-center mb-4">
                        <div class="d-inline-block p-3 rounded-circle bg-white shadow-sm mb-3">
                            <i class="bi bi-person-plus-fill fs-3" style="color: #4facfe;"></i>
                        </div>
                        <h3 class="fw-bold text-dark">Tạo Tài Khoản Mới</h3>
                        <p class="text-muted">Tham gia cùng "it for life" ngay hôm nay</p>
                    </div>

                    <form action="/dangky" method="post" class="needs-validation" novalidate> 
                        
                        <div class="row g-3">
                            
                            <div class="col-md-6"> 
                                <label for="HoVaTen" class="form-label fw-semibold text-secondary small mb-1">Họ và tên</label> 
                                <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                    <span class="input-group-text border-0 icon-box"><i class="bi bi-person-fill"></i></span>
                                    <input type="text" class="form-control border-0 py-2" id="HoVaTen" name="HoVaTen" placeholder="Ví dụ: Nguyễn Văn A" required /> 
                                </div>
                            </div> 
                             
                            <div class="col-md-6"> 
                                <label for="Email" class="form-label fw-semibold text-secondary small mb-1">Email</label> 
                                <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                    <span class="input-group-text border-0 icon-box"><i class="bi bi-envelope-fill"></i></span>
                                    <input type="email" class="form-control border-0 py-2" id="Email" name="Email" placeholder="email@domain.com" /> 
                                </div>
                            </div> 
                             
                            <div class="col-md-6"> 
                                <label for="TenDangNhap" class="form-label fw-semibold text-secondary small mb-1">Tên đăng nhập</label> 
                                <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                    <span class="input-group-text border-0 icon-box"><i class="bi bi-person-badge-fill"></i></span>
                                    <input type="text" class="form-control border-0 py-2" id="TenDangNhap" name="TenDangNhap" placeholder="Nhập tên đăng nhập" required /> 
                                </div>
                            </div> 
                             
                            <div class="col-md-6"> 
                                <label for="HinhAnh" class="form-label fw-semibold text-secondary small mb-1">Hình ảnh đại diện</label> 
                                <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                    <span class="input-group-text border-0 icon-box"><i class="bi bi-image-fill"></i></span>
                                    <input type="text" class="form-control border-0 py-2" id="HinhAnh" name="HinhAnh" placeholder="Đường dẫn link ảnh..." /> 
                                </div>
                            </div> 
                             
                            <div class="col-md-6"> 
                                <label for="MatKhau" class="form-label fw-semibold text-secondary small mb-1">Mật khẩu</label> 
                                <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                    <span class="input-group-text border-0 icon-box"><i class="bi bi-lock-fill"></i></span>
                                    <input type="password" class="form-control border-0 py-2" id="MatKhau" name="MatKhau" placeholder="Tạo mật khẩu" required /> 
                                </div>
                            </div> 
                             
                            <div class="col-md-6"> 
                                <label for="XacNhanMatKhau" class="form-label fw-semibold text-secondary small mb-1">Xác nhận mật khẩu</label> 
                                <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                    <span class="input-group-text border-0 icon-box"><i class="bi bi-shield-lock-fill"></i></span>
                                    <input type="password" class="form-control border-0 py-2" id="XacNhanMatKhau" name="XacNhanMatKhau" placeholder="Nhập lại mật khẩu" required /> 
                                </div>
                            </div> 

                        </div>
                         
                        <div class="mt-4 pt-2">
                            <button type="submit" class="btn btn-gradient w-100 py-2 rounded-pill fw-bold text-uppercase">
                                <i class="bi bi-rocket-takeoff-fill me-1"></i> Đăng ký tài khoản
                            </button> 
                        </div>

                        <div class="text-center mt-4">
                            <span class="text-muted small">Đã có tài khoản? <a href="/dangnhap" class="text-decoration-none fw-semibold" style="color: #a872fa;">Đăng nhập tại đây</a></span>
                        </div>

                    </form> 
                </div> 
                </div>
        </div>
    </div>
     
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script> 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> 
    <script> 
        // Form Validation Bootstrap
        (function() { 
            'use strict'; 
            const forms = document.querySelectorAll('.needs-validation'); 
            Array.from(forms).forEach(form => { 
                form.addEventListener('submit', event => { 
                    if (!form.checkValidity()) { 
                        event.preventDefault(); 
                        event.stopPropagation(); 
                    } 
                    form.classList.add('was-validated'); 
                }, false); 
            }); 
        })(); 
    </script> 
</body> 
</html>