<!DOCTYPE html> 
<html lang="vi"> 
<head> 
    <meta charset="utf-8" /> 
    <meta name="viewport" content="width=device-width, initial-scale=1" /> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" /> 
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <title>Đăng nhập - it for lie</title> 

    <style>
        /* Toàn bộ trang web sẽ dùng nền Gradient chuyển màu xanh - tím mộng mơ */
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        /* Hiệu ứng kính mờ (Glassmorphism) cho thẻ Form */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        /* Nút bấm chuyển màu */
        .btn-gradient {
            background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
            border: none;
            color: white;
            transition: all 0.3s ease;
        }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 254, 0.4);
            color: white;
        }

        /* Ô nhập liệu */
        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(142, 197, 252, 0.25);
            border-color: #8ec5fc;
        }
        
        .icon-box {
            background: #f8f9fa;
            color: #4facfe;
        }
    </style>
</head> 
 
<body> 
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                
                <div class="glass-card p-4 p-sm-5"> 
                    
                    <div class="text-center mb-4">
                        <div class="d-inline-block p-3 rounded-circle bg-white shadow-sm mb-3">
                            <i class="bi bi-star-fill text-warning fs-3"></i>
                        </div>
                        <h3 class="fw-bold text-dark">Chào mừng trở lại!</h3>
                        <p class="text-muted">Đăng nhập để tiếp tục vào "it for life"</p>
                    </div>

                    <form action="/dangnhap" method="post" class="needs-validation" novalidate> 
                        
                        <div class="mb-4"> 
                            <label for="TenDangNhap" class="form-label fw-semibold text-secondary small mb-1">Tên đăng nhập</label> 
                            <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                <span class="input-group-text border-0 icon-box"><i class="bi bi-person-badge-fill"></i></span>
                                <input type="text" class="form-control border-0 py-2" id="TenDangNhap" name="TenDangNhap" placeholder="Nhập tên đăng nhập" required /> 
                            </div>
                        </div> 
                         
                        <div class="mb-4"> 
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label for="MatKhau" class="form-label fw-semibold text-secondary small mb-0">Mật khẩu</label> 
                                <a href="#" class="text-decoration-none small" style="color: #4facfe; font-weight: 500;">Quên mật khẩu?</a>
                            </div>
                            <div class="input-group rounded-3 overflow-hidden shadow-sm border bg-white">
                                <span class="input-group-text border-0 icon-box"><i class="bi bi-lock-fill"></i></span>
                                <input type="password" class="form-control border-0 py-2" id="MatKhau" name="MatKhau" placeholder="Nhập mật khẩu" required /> 
                            </div>
                        </div> 

                        <div class="mb-4 form-check">
                            <input type="checkbox" class="form-check-input shadow-sm cursor-pointer" id="GhiNho">
                            <label class="form-check-label text-muted small" style="cursor: pointer;" for="GhiNho">Ghi nhớ đăng nhập</label>
                        </div>
                         
                        <div class="mt-4">
                            <button type="submit" class="btn btn-gradient w-100 py-2 rounded-pill fw-bold text-uppercase">
                                Đăng nhập ngay <i class="bi bi-arrow-right-circle ms-1"></i>
                            </button> 
                        </div>

                        <div class="text-center mt-4">
                            <span class="text-muted small">Chưa có tài khoản? <a href="/dangky" class="text-decoration-none fw-semibold" style="color: #a872fa;">Đăng ký tại đây</a></span>
                        </div>
                    </form> 
                </div> </div>
        </div>
    </div>
     
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script> 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> 
</body> 
</html>