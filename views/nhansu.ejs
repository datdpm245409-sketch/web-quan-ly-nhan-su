<!DOCTYPE html> 
<html lang="vi"> 
<head> 
    <meta charset="utf-8" /> 
    <meta name="viewport" content="width=device-width, initial-scale=1" /> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" /> 
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Quản lý nhân sự - it for life</title> 
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
        .table-custom th { background-color: #eef2f7; color: #6c757d; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; padding: 1rem; }
        .table-custom td { padding: 1rem; vertical-align: middle; }
        .avatar { width: 40px; height: 40px; object-fit: cover; border-radius: 50%; }
        .badge-soft-success { background-color: rgba(28, 200, 138, 0.1); color: #1cc88a; }
    </style>
</head> 
<body> 

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1">Danh sách nhân sự</h3>
				<div class="d-flex gap-2">
    <button class="btn btn-success rounded-pill" data-bs-toggle="modal" data-bs-target="#modalPhongBan">
        <i class="bi bi-plus-circle"></i> Thêm phòng ban
    </button>
    <button class="btn btn-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#modalNhanVien">
        <i class="bi bi-person-plus"></i> Thêm nhân viên
    </button>
</div>

<div class="modal fade" id="modalPhongBan" tabindex="-1">
    <div class="modal-dialog">
        <form class="modal-content" action="/phong-ban/them" method="POST">
            <div class="modal-header"><h5>Thêm phòng ban mới</h5></div>
            <div class="modal-body">
                <input type="text" name="TenPhongBan" class="form-control" placeholder="Tên phòng ban..." required>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Lưu lại</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="modalNhanVien" tabindex="-1">
    <div class="modal-dialog">
        <form class="modal-content" action="/nhan-su/them" method="POST">
            <div class="modal-header"><h5>Tạo tài khoản nhân viên</h5></div>
            <div class="modal-body">
                <div class="mb-3"><input type="text" name="HoVaTen" class="form-control" placeholder="Họ và Tên" required></div>
                <div class="mb-3"><input type="text" name="TenDangNhap" class="form-control" placeholder="Tên đăng nhập" required></div>
                <div class="mb-3"><input type="password" name="MatKhau" class="form-control" placeholder="Mật khẩu" required></div>
                <div class="mb-3">
                    <select name="PhongBan" class="form-select">
                        <option value="Kinh doanh">Kinh doanh</option>
                        <option value="Kỹ thuật">Kỹ thuật</option>
                        <option value="Nhân sự">Nhân sự</option>
                    </select>
                </div>
                <div class="mb-3"><input type="text" name="ChucVu" class="form-control" placeholder="Chức vụ (VD: Trưởng phòng)"></div>
            </div>
            <div class="modal-footer"><button type="submit" class="btn btn-primary">Tạo nhân viên</button></div>
        </form>
    </div>
</div>
                <p class="text-muted mb-0">Quản lý toàn bộ hồ sơ nhân viên trong công ty</p>
            </div>
            
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-custom mb-0">
                        <thead>
                            <tr>
                                <th>Nhân viên</th>
                                <th>Tài khoản</th>
                                <th>Phòng ban</th>
                                <th>Chức vụ</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% nhanviens.forEach(function(nv) { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="<%= nv.HinhAnh ? nv.HinhAnh : 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>" class="avatar me-3 shadow-sm" alt="Avatar">
                                            <div>
                                                <h6 class="mb-0 fw-bold"><%= nv.HoVaTen %></h6>
                                                <small class="text-muted"><%= nv.Email || 'Chưa cập nhật email' %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="text-secondary"><%= nv.TenDangNhap %></span></td>
                                    <td><span class="fw-medium"><%= nv.PhongBan || 'Chưa phân bổ' %></span></td>
                                    <td><%= nv.ChucVu || 'Nhân viên' %></td>
                                    <td>
									<td class="text-end">
    <button class="btn btn-sm btn-outline-warning rounded-circle me-2" 
            data-bs-toggle="modal" 
            data-bs-target="#editModal<%= nv._id %>">
        <i class="bi bi-pencil-fill"></i>
    </button>

    <div class="modal fade" id="editModal<%= nv._id %>" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-start">
                <form action="/nhan-su/sua-chuc-vu/<%= nv._id %>" method="POST">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title fw-bold">Cập nhật vị trí: <%= nv.HoVaTen %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Phòng ban</label>
                            <select name="PhongBan" class="form-select">
                                <option value="Kinh doanh" <%= nv.PhongBan === 'Kinh doanh' ? 'selected' : '' %>>Kinh doanh</option>
                                <option value="Kỹ thuật" <%= nv.PhongBan === 'Kỹ thuật' ? 'selected' : '' %>>Kỹ thuật</option>
                                <option value="Nhân sự" <%= nv.PhongBan === 'Nhân sự' ? 'selected' : '' %>>Nhân sự</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chức vụ</label>
                            <input type="text" name="ChucVu" class="form-control" value="<%= nv.ChucVu %>" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-warning fw-bold">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</td>
                                        <span class="badge badge-soft-success px-2 py-1 rounded-pill">Đang làm việc</span>
                                    </td>
                                    <td class="text-end">
                                        <a href="#" class="btn btn-sm btn-light text-primary rounded-circle" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="#" class="btn btn-sm btn-light text-warning rounded-circle" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>

                            <% if(nhanviens.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Chưa có dữ liệu nhân sự nào.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> 
</body> 
</html>